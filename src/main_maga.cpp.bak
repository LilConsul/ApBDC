/**
 ******************************************************************************
 * @file    main.cpp
 * @brief   Main application - LIS3MDL magnetometer demo with button trigger
 * @author  ApBDC Team
 ******************************************************************************
 * @attention
 *
 * This application demonstrates the LIS3MDL magnetometer driver with
 * button-triggered readings. Press the user button (PA0) to read and
 * display magnetic field data.
 *
 ******************************************************************************
 */

/* Includes ------------------------------------------------------------------*/
#include <stdio.h>
#include <stdlib.h>
#include "diag/trace.h"
#include "stm32f4xx_hal.h"
#include "stm32f413h_discovery.h"

/* Driver includes */
#include "sensor/i2c_dma.h"
#include "sensor/lis3mdl.h"

/* Private defines -----------------------------------------------------------*/
#define BUTTON_PIN                               GPIO_PIN_0
#define BUTTON_GPIO_PORT                         GPIOA
#define BUTTON_GPIO_CLK_ENABLE()                 __HAL_RCC_GPIOA_CLK_ENABLE()
#define BUTTON_EXTI_IRQn                         EXTI0_IRQn

/* Private variables ---------------------------------------------------------*/
static volatile uint8_t button_pressed_flag = 0;

/* Private function prototypes -----------------------------------------------*/
static void Button_GPIO_Init(void);
static void ReadAndDisplayMagnetometer(void);

/* Main application ----------------------------------------------------------*/
int main(void) {
    HAL_Init();
    
    // Initialize LED for status indication
    BSP_LED_Init(LED3);
    
    // Initialize button GPIO with interrupt
    Button_GPIO_Init();
    
    // Initialize I2C with DMA
    I2C_DMA_Init();
    
    // Initialize LIS3MDL magnetometer with default configuration
    LIS3MDL_StatusTypeDef mag_status = LIS3MDL_Init();
    
    if (mag_status != LIS3MDL_OK) {
        trace_printf("ERROR: LIS3MDL initialization failed (status=%d)\n", mag_status);
        trace_printf("Check wiring and I2C address (SA1 pin configuration)\n");
        BSP_LED_On(LED4);
        while (1) {
            // Halt on error
        }
    }
    
    trace_printf("===========================================\n");
    trace_printf("LIS3MDL Magnetometer Demo\n");
    trace_printf("===========================================\n");
    trace_printf("Configuration:\n");
    trace_printf("  - Full Scale: ±4 gauss\n");
    trace_printf("  - ODR: 10 Hz\n");
    trace_printf("  - Mode: Continuous\n");
    trace_printf("  - Sensitivity: %.2f LSB/gauss\n", LIS3MDL_GetSensitivity());
    trace_printf("===========================================\n");
    trace_printf("Press USER button (PA0) to read magnetometer\n");
    trace_printf("===========================================\n\n");

    // Main loop - wait for button press
    while (1) {
        if (button_pressed_flag) {
            button_pressed_flag = 0;
            ReadAndDisplayMagnetometer();
        }
        
        // Enter low-power mode while waiting for interrupt
        __WFI();  // Wait For Interrupt
    }
}

/**
 * @brief  Configure button GPIO as external interrupt
 * @retval None
 */
static void Button_GPIO_Init(void) {
    GPIO_InitTypeDef GPIO_InitStruct = {0};
    
    // Enable GPIO clock
    BUTTON_GPIO_CLK_ENABLE();
    
    // Configure GPIO pin as interrupt on rising edge
    GPIO_InitStruct.Pin = BUTTON_PIN;
    GPIO_InitStruct.Mode = GPIO_MODE_IT_RISING;
    GPIO_InitStruct.Pull = GPIO_NOPULL;
    HAL_GPIO_Init(BUTTON_GPIO_PORT, &GPIO_InitStruct);
    
    // Set EXTI interrupt priority and enable it
    HAL_NVIC_SetPriority(BUTTON_EXTI_IRQn, 0, 0);
    HAL_NVIC_EnableIRQ(BUTTON_EXTI_IRQn);
}

/**
 * @brief  Read magnetometer and display data
 * @retval None
 */
static void ReadAndDisplayMagnetometer(void) {
    LIS3MDL_MagDataTypeDef mag_data;
    LIS3MDL_RawDataTypeDef raw_data;
    LIS3MDL_StatusTypeDef status;
    
    trace_printf("\n--- Button Pressed ---\n");
    BSP_LED_On(LED3);
    
    // Optional: Wait for data ready (with timeout)
    status = LIS3MDL_WaitForDataReady(100);
    if (status == LIS3MDL_TIMEOUT) {
        trace_printf("WARNING: Data ready timeout\n");
    }
    
    // Read raw magnetometer data
    status = LIS3MDL_ReadRawData(&raw_data);
    if (status != LIS3MDL_OK) {
        trace_printf("ERROR: Failed to read raw data (status=%d)\n", status);
        BSP_LED_On(LED4);
        BSP_LED_Off(LED3);
        return;
    }
    
    // Read calibrated magnetometer data (in gauss)
    status = LIS3MDL_ReadMagData(&mag_data);
    if (status != LIS3MDL_OK) {
        trace_printf("ERROR: Failed to read mag data (status=%d)\n", status);
        BSP_LED_On(LED4);
        BSP_LED_Off(LED3);
        return;
    }
    
    // Display results
    trace_printf("Raw Data:\n");
    trace_printf("  X: %6d  Y: %6d  Z: %6d\n", raw_data.x, raw_data.y, raw_data.z);
    trace_printf("Magnetic Field (gauss):\n");
    trace_printf("  X: %+7.4f  Y: %+7.4f  Z: %+7.4f\n", mag_data.x, mag_data.y, mag_data.z);
    trace_printf("--- Read Complete ---\n\n");
    
    BSP_LED_Off(LED3);
}

/**
 * @brief  GPIO EXTI callback - called when button interrupt occurs
 * @param  GPIO_Pin: Pin number that triggered the interrupt
 * @retval None
 */
void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin) {
    if (GPIO_Pin == BUTTON_PIN) {
        button_pressed_flag = 1;
    }
}
